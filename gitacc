#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# gitacc — Smart GitHub account switcher for SSH-based repos
# Usage: gitacc [list|add|delete|status|help|--version|<account-name>]
# Accounts are stored in ~/.config/gitacc/accounts.conf
# =============================================================================

VERSION="0.1.0"

CONFIG_DIR="${HOME}/.config/gitacc"
ACCOUNTS_FILE="${CONFIG_DIR}/accounts.conf"
SSH_CONFIG_FILE="${HOME}/.ssh/config"
USAGE_FILE="${CONFIG_DIR}/usage.conf"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

GITACC_SELECTION=""
GITACC_CANCELLED=0
GITACC_ACTION=""

log_info()  { printf "${BLUE}ℹ${NC}  %s\n" "$1"; }
log_ok()    { printf "${GREEN}✔${NC}  %s\n" "$1"; }
log_warn()  { printf "${YELLOW}⚠${NC}  %s\n" "$1"; }
log_err()   { printf "${RED}✖${NC}  %s\n" "$1" >&2; }
log_title() { printf "\n${BOLD}${CYAN}%s${NC}\n" "$1"; }

usage() {
    cat <<EOF
gitacc — Smart GitHub account switcher

Version:
    ${VERSION}

Usage:
  gitacc                    Interactive account selector
  gitacc <name>             Switch to account <name>
  gitacc list               List all configured accounts
  gitacc add                Add a new account interactively
  gitacc delete <name>      Delete an account
  gitacc status             Show current repo and SSH state
    gitacc help               Show this help
    gitacc --help             Show this help
    gitacc --version          Show the current version

What it does when switching:
  • Loads the right SSH key into ssh-agent
  • Sets repo-level git user.name / user.email
  • Rewrites the origin remote to use the matching GitHub SSH host alias
  • Tests the GitHub SSH connection
EOF
}

print_version() {
        echo "gitacc ${VERSION}"
}

die() {
    log_err "$1"
    exit 1
}

# =============================================================================
# Config management
# =============================================================================

ensure_config_dir() {
    mkdir -p "$CONFIG_DIR"
}

ensure_usage_file() {
    ensure_config_dir
    if [[ ! -f "$USAGE_FILE" ]]; then
        : > "$USAGE_FILE"
    fi
}

ensure_accounts_file() {
    ensure_config_dir
    if [[ ! -f "$ACCOUNTS_FILE" ]]; then
        cat > "$ACCOUNTS_FILE" <<'DEFAULT'
# Add accounts with: gitacc add
# Example format:
# [work]
# name = Your Name
# email = you@company.com
# key = ~/.ssh/id_ed25519_work
# host_alias = github-work
DEFAULT
    fi
}

has_accounts() {
    ensure_accounts_file
    grep -qE '^\[[^]]+\]$' "$ACCOUNTS_FILE"
}

show_no_accounts_message() {
    echo ""
    log_warn "No GitHub accounts configured yet."
    echo "Run: gitacc add"
    echo "Config file: ${ACCOUNTS_FILE}"
    echo ""
}

count_accounts() {
    ensure_accounts_file
    awk 'BEGIN { count = 0 } /^\[[^]]+\]$/ { count++ } END { print count }' "$ACCOUNTS_FILE"
}

list_account_names() {
    ensure_accounts_file
    awk -F'[][]' '/^\[.*\]$/ { print $2 }' "$ACCOUNTS_FILE"
}

account_exists() {
    local name="$1"
    list_account_names | grep -qx "$name"
}

get_account_field() {
    local name="$1" field="$2"
    awk -F' = ' -v acc="$name" -v f="$field" '
        $0 ~ "^\\[" acc "\\]$" { in_section=1; next }
        /^\[/ { in_section=0 }
        in_section && $1 == f { print $2; exit }
    ' "$ACCOUNTS_FILE"
}

expand_path() {
    local path="$1"
    path="${path/#\~/$HOME}"
    echo "$path"
}

get_current_account_name() {
    local remote_host git_email account_name

    remote_host=$(get_remote_host)
    account_name=$(get_account_name_by_host_alias "$remote_host")
    if [[ -n "$account_name" ]]; then
        echo "$account_name"
        return
    fi

    git_email=$(git config user.email 2>/dev/null || true)
    account_name=$(get_account_name_by_email "$git_email")
    echo "$account_name"
}

trim_input() {
    printf '%s' "$1" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

is_quit_input() {
    local input
    input=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')

    case "$input" in
        q|quit|exit)
            return 0
            ;;
    esac

    return 1
}

prompt_text() {
    local var_name="$1"
    local prompt="$2"
    local allow_empty="${3:-0}"
    local suppress_cancel_notice="${4:-0}"
    local value=""

    while true; do
        if ! IFS= read -r -p "$prompt" value; then
            if [[ "$suppress_cancel_notice" != "1" ]]; then
                log_info "Cancelled."
            fi
            return 130
        fi

        value=$(trim_input "$value")

        if is_quit_input "$value"; then
            if [[ "$suppress_cancel_notice" != "1" ]]; then
                log_info "Cancelled."
            fi
            return 130
        fi

        if [[ "$allow_empty" == "1" || -n "$value" ]]; then
            printf -v "$var_name" '%s' "$value"
            return 0
        fi

        log_warn "Please enter a value or type 'q' to cancel."
    done
}

prompt_text_with_default() {
    local var_name="$1"
    local prompt="$2"
    local default_value="$3"
    local value=""

    if ! prompt_text value "$prompt" 1; then
        return $?
    fi

    if [[ -z "$value" ]]; then
        value="$default_value"
    fi

    printf -v "$var_name" '%s' "$value"
    return 0
}

prompt_yes_no() {
    local var_name="$1"
    local prompt="$2"
    local default_answer="${3:-n}"
    local value=""
    local normalized_default normalized_value

    normalized_default=$(printf '%s' "$default_answer" | tr '[:upper:]' '[:lower:]')

    while true; do
        if ! IFS= read -r -p "$prompt" value; then
            log_info "Cancelled."
            return 130
        fi

        value=$(trim_input "$value")

        if is_quit_input "$value"; then
            log_info "Cancelled."
            return 130
        fi

        if [[ -z "$value" ]]; then
            value="$normalized_default"
        fi

        normalized_value=$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]')

        case "$normalized_value" in
            y|yes)
                printf -v "$var_name" 'yes'
                return 0
                ;;
            n|no)
                printf -v "$var_name" 'no'
                return 0
                ;;
        esac

        log_warn "Please answer y, n, or q to cancel."
    done
}

# =============================================================================
# SSH config management
# =============================================================================

ensure_ssh_config_header() {
    if [[ ! -f "$SSH_CONFIG_FILE" ]]; then
        touch "$SSH_CONFIG_FILE"
        chmod 600 "$SSH_CONFIG_FILE"
    fi
}

ssh_host_exists() {
    local host="$1"
    grep -qE "^Host\s+${host}\$" "$SSH_CONFIG_FILE"
}

add_ssh_host() {
    local host="$1" key="$2"
    ensure_ssh_config_header
    if ssh_host_exists "$host"; then
        return
    fi
    cat >> "$SSH_CONFIG_FILE" <<EOF

Host ${host}
  HostName github.com
  User git
  IdentityFile ${key}
  IdentitiesOnly yes
EOF
}

remove_ssh_host() {
    local host="$1"
    if [[ ! -f "$SSH_CONFIG_FILE" ]]; then
        return
    fi
    if ! ssh_host_exists "$host"; then
        return
    fi
    awk -v host="$host" '
        /^Host / { in_block=($2 == host) }
        !in_block { print }
    ' "$SSH_CONFIG_FILE" > "${SSH_CONFIG_FILE}.tmp"
    mv "${SSH_CONFIG_FILE}.tmp" "$SSH_CONFIG_FILE"
}

# =============================================================================
# SSH / Git helpers
# =============================================================================

ensure_key() {
    local key="$1" label="$2"
    if [[ ! -f "$key" ]]; then
        die "SSH key for ${label} not found: ${key}"
    fi
    if [[ ! -f "${key}.pub" ]]; then
        die "Public key missing for ${label}: ${key}.pub"
    fi
}

ensure_ssh_agent() {
    if ! pgrep -u "$(id -u)" ssh-agent >/dev/null 2>&1; then
        log_warn "ssh-agent not running. Starting it..."
        eval "$(ssh-agent -s)" >/dev/null
    fi
    if [[ -z "${SSH_AUTH_SOCK:-}" ]]; then
        eval "$(ssh-agent -s)" >/dev/null
    fi
}

in_git_repo() {
    git rev-parse --is-inside-work-tree >/dev/null 2>&1
}

get_remote_host() {
    local url
    url=$(git remote get-url origin 2>/dev/null || true)
    if [[ -z "$url" ]]; then
        echo ""
        return
    fi
    if [[ "$url" =~ ^git@([^:]+): ]]; then
        echo "${BASH_REMATCH[1]}"
    else
        echo "$url"
    fi
}

get_account_name_by_host_alias() {
    local target="$1"
    local name key host
    while IFS= read -r name; do
        host=$(get_account_field "$name" host_alias)
        if [[ "$host" == "$target" ]]; then
            echo "$name"
            return
        fi
    done < <(list_account_names)
}

get_account_name_by_email() {
    local target="$1"
    local name email
    while IFS= read -r name; do
        email=$(get_account_field "$name" email)
        if [[ "$email" == "$target" ]]; then
            echo "$name"
            return
        fi
    done < <(list_account_names)
}

rewrite_remote() {
    local target_host="$1"
    local current_url
    current_url=$(git remote get-url origin 2>/dev/null || true)

    if [[ -z "$current_url" ]]; then
        log_warn "No 'origin' remote found in this repo. Skipping remote rewrite."
        return
    fi

    if [[ ! "$current_url" =~ ^git@([^:]+):(.+)$ ]]; then
        log_warn "Origin is not an SSH-style URL: ${current_url}"
        return
    fi

    local repo_path="${BASH_REMATCH[2]}"
    local new_url="git@${target_host}:${repo_path}"

    if [[ "$current_url" == "$new_url" ]]; then
        log_info "Remote already points to ${target_host}."
    else
        git remote set-url origin "$new_url"
        log_ok "Remote updated: ${current_url} → ${new_url}"
    fi
}

set_git_identity() {
    local name="$1" email="$2"
    git config user.name "$name"
    git config user.email "$email"
    log_ok "Git identity set: ${name} <${email}>"
}

switch_ssh_key() {
    local key="$1" label="$2"
    ensure_ssh_agent
    ssh-add -D 2>/dev/null || true
    if ssh-add "$key" 2>/dev/null; then
        log_ok "Loaded ${label} SSH key: ${key}"
    else
        die "Failed to load ${label} SSH key: ${key}"
    fi
}

test_github_connection() {
    local host="$1" label="$2"
    local output
    log_info "Testing GitHub SSH connection as ${label}..."

    if output=$(ssh -T "$host" 2>&1); then
        log_ok "GitHub says: ${output}"
    else
        local code=$?
        if [[ "$code" -eq 1 && "$output" == *"successfully authenticated"* ]]; then
            log_ok "GitHub says: ${output}"
        else
            log_err "SSH test failed for ${label} (${host})."
            log_err "Output: ${output}"
            log_err "Hint: make sure the public key is added to the ${label} GitHub account."
            return 1
        fi
    fi
}

github_connection_works() {
    local host="$1"
    local output_var="$2"
    local output=""
    local exit_code=0

    if output=$(ssh -T "$host" 2>&1); then
        printf -v "$output_var" '%s' "$output"
        return 0
    fi

    exit_code=$?
    printf -v "$output_var" '%s' "$output"

    if [[ "$exit_code" -eq 1 && "$output" == *"successfully authenticated"* ]]; then
        return 0
    fi

    return 1
}

get_account_usage_count() {
    local name="$1"
    local count

    ensure_usage_file
    count=$(awk -F'=' -v target="$name" '$1 == target { print $2; found = 1; exit } END { if (!found) print 0 }' "$USAGE_FILE")
    echo "${count:-0}"
}

record_account_usage() {
    local name="$1"
    local current_count new_count

    ensure_usage_file
    current_count=$(get_account_usage_count "$name")
    new_count=$((current_count + 1))

    if grep -qE "^${name}=" "$USAGE_FILE"; then
        awk -F'=' -v target="$name" -v replacement="$new_count" '
            $1 == target { print $1 "=" replacement; next }
            { print }
        ' "$USAGE_FILE" > "${USAGE_FILE}.tmp"
        mv "${USAGE_FILE}.tmp" "$USAGE_FILE"
    else
        printf '%s=%s\n' "$name" "$new_count" >> "$USAGE_FILE"
    fi
}

get_most_used_account() {
    local result

    ensure_usage_file
    result=$(awk -F'=' 'NF == 2 && $2 ~ /^[0-9]+$/ { if ($2 > max) { max = $2; name = $1 } } END { if (name != "") print name "=" max }' "$USAGE_FILE")
    echo "$result"
}

remove_account_usage() {
    local name="$1"

    ensure_usage_file
    if ! grep -qE "^${name}=" "$USAGE_FILE"; then
        return
    fi

    awk -F'=' -v target="$name" '$1 != target { print }' "$USAGE_FILE" > "${USAGE_FILE}.tmp"
    mv "${USAGE_FILE}.tmp" "$USAGE_FILE"
}

open_github_ssh_settings() {
    local url="https://github.com/settings/keys"

    if command -v open >/dev/null 2>&1; then
        open "$url" >/dev/null 2>&1 || true
        log_info "Opened GitHub SSH settings: ${url}"
        return
    fi

    log_info "Open this page in your browser: ${url}"
}

guide_github_key_setup() {
    local key_path="$1"
    local email="$2"
    local title_hint

    title_hint="$(hostname -s 2>/dev/null || echo mac)-${email}"

    echo ""
    log_title "GitHub SSH Key Setup"

    if command -v pbcopy >/dev/null 2>&1; then
        pbcopy < "${key_path}.pub"
        log_ok "Public key copied to your clipboard."
    else
        log_warn "Clipboard integration is unavailable; copy the key manually."
    fi

    echo "1. Open GitHub SSH keys settings."
    echo "2. Click 'New SSH key'."
    echo "3. Suggested title: ${title_hint}"
    echo "4. Paste the public key and save it."
    echo ""
    log_info "Public key:"
    cat "${key_path}.pub"
    echo ""
}

wait_for_github_key_registration() {
    local host="$1"
    local output=""
    local response=""

    while true; do
        if ! prompt_text response "Press Enter to re-test, 'o' to open settings, 's' to skip verification, or 'q' to cancel: " 1 1; then
            log_warn "Cancelled GitHub verification. The account is saved; test later with: ssh -T ${host}"
            return 0
        fi

        case "$response" in
            o|O|open)
                open_github_ssh_settings
                continue
                ;;
            s|S|skip)
                log_warn "Skipped GitHub verification. You can test later with: ssh -T ${host}"
                return 0
                ;;
            "")
                if github_connection_works "$host" output; then
                    log_ok "GitHub says: ${output}"
                    return 0
                fi

                log_warn "GitHub has not accepted the key yet."
                log_warn "Last response: ${output}"
                ;;
            *)
                log_warn "Unknown choice: ${response}"
                ;;
        esac
    done
}

# =============================================================================
# Interactive selector (pure bash, arrow keys + number + name)
# =============================================================================

run_arrow_menu() {
    local title="$1"
    local details="$2"
    shift 2

    if [[ $# -eq 0 ]]; then
        return 1
    fi

    if ! command -v python3 >/dev/null 2>&1; then
        return 1
    fi

    python3 - "$title" "$details" "$@" <<'PY'
import os
import select
import sys
import termios
import tty

title = sys.argv[1]
details = sys.argv[2]
items = sys.argv[3:]

tty_in = open('/dev/tty', 'rb', buffering=0)
tty_out = open('/dev/tty', 'w', buffering=1)
fd = tty_in.fileno()
old = termios.tcgetattr(fd)
selected = 0

def write_line(text=''):
    tty_out.write(text + '\r\n')

def draw():
    tty_out.write('\033[H\033[2J')
    write_line(title)
    write_line()
    if details:
        for line in details.splitlines():
            write_line(line)
        write_line()
    for idx, item in enumerate(items):
        prefix = '▶' if idx == selected else ' '
        write_line(f'  {prefix} {item}')
    tty_out.flush()

def read_key():
    first = tty_in.read(1)
    if first in (b'\r', b'\n'):
        return 'enter'
    if first in (b'q', b'Q'):
        return 'quit'
    if first == b'\x1b':
        ready, _, _ = select.select([fd], [], [], 0.12)
        if not ready:
            return 'quit'
        second = tty_in.read(1)
        if second != b'[':
            return 'quit'
        ready, _, _ = select.select([fd], [], [], 0.12)
        if not ready:
            return 'quit'
        third = tty_in.read(1)
        if third == b'A':
            return 'up'
        if third == b'B':
            return 'down'
        return 'other'
    return 'other'

try:
    tty_out.write('\033[?1049h\033[?25l')
    tty.setraw(fd)
    while True:
        draw()
        key = read_key()
        if key == 'up':
            selected = (selected - 1) % len(items)
        elif key == 'down':
            selected = (selected + 1) % len(items)
        elif key == 'enter':
            sys.stdout.write(str(selected))
            sys.stdout.flush()
            break
        elif key == 'quit':
            sys.stdout.write('cancel')
            sys.stdout.flush()
            break
finally:
    termios.tcsetattr(fd, termios.TCSADRAIN, old)
    tty_out.write('\033[?25h\033[?1049l')
    tty_out.flush()
    tty_in.close()
    tty_out.close()
PY
}

show_text_screen() {
    local title="$1"
    local body="$2"

    if ! command -v python3 >/dev/null 2>&1; then
        echo ""
        log_title "$title"
        printf '%s\n' "$body"
        return
    fi

    python3 - "$title" "$body" <<'PY'
import sys
import termios
import tty

title = sys.argv[1]
body = sys.argv[2]

tty_in = open('/dev/tty', 'rb', buffering=0)
tty_out = open('/dev/tty', 'w', buffering=1)
fd = tty_in.fileno()
old = termios.tcgetattr(fd)

def write_line(text=''):
    tty_out.write(text + '\r\n')

try:
    tty_out.write('\033[?1049h\033[?25l')
    tty.setraw(fd)
    tty_out.write('\033[H\033[2J')
    write_line(title)
    write_line()
    for line in body.splitlines():
        write_line(line)
    write_line()
    write_line('Press any key to go back.')
    tty_out.flush()
    tty_in.read(1)
finally:
    termios.tcsetattr(fd, termios.TCSADRAIN, old)
    tty_out.write('\033[?25h\033[?1049l')
    tty_out.flush()
    tty_in.close()
    tty_out.close()
PY
}

build_accounts_screen_text() {
    local output=""
    local name email host usage_count key_path

    while IFS= read -r name; do
        email=$(get_account_field "$name" email)
        host=$(get_account_field "$name" host_alias)
        key_path=$(expand_path "$(get_account_field "$name" key)")
        usage_count=$(get_account_usage_count "$name")
        output+="${name} <${email}>"$'\n'
        output+="  host: ${host}"$'\n'
        output+="  key: ${key_path}"$'\n'
        output+="  switches: ${usage_count}"$'\n\n'
    done < <(list_account_names)

    printf '%s' "$output"
}

print_account_list() {
    local options=()
    local name email host key_path usage_count i

    while IFS= read -r name; do
        options+=("$name")
    done < <(list_account_names)

    if [[ ${#options[@]} -eq 0 ]]; then
        show_no_accounts_message
        return 1
    fi

    log_title "Configured GitHub accounts"
    for ((i=0; i<${#options[@]}; i++)); do
        name="${options[$i]}"
        email=$(get_account_field "$name" email)
        host=$(get_account_field "$name" host_alias)
        key_path=$(expand_path "$(get_account_field "$name" key)")
        usage_count=$(get_account_usage_count "$name")
        printf "  %d) %-15s <%s>\n" "$((i + 1))" "$name" "$email"
        printf "      host: %s\n" "$host"
        printf "      key: %s\n" "$key_path"
        printf "      switches: %s\n" "$usage_count"
    done
    echo ""
}

selector_preview_index() {
    local query="$1"
    local options=()
    local lowered_query lowered_option name idx i

    while IFS= read -r name; do
        options+=("$name")
    done < <(list_account_names)

    if [[ "$query" =~ ^[0-9]+$ ]]; then
        idx=$((10#$query - 1))
        if [[ $idx -ge 0 && $idx -lt ${#options[@]} ]]; then
            echo "$idx"
            return 0
        fi
        return 1
    fi

    lowered_query=$(printf '%s' "$query" | tr '[:upper:]' '[:lower:]')
    for ((i=0; i<${#options[@]}; i++)); do
        lowered_option=$(printf '%s' "${options[$i]}" | tr '[:upper:]' '[:lower:]')
        case "$lowered_option" in
            "$lowered_query"|"$lowered_query"*)
                echo "$i"
                return 0
                ;;
        esac
    done

    return 1
}

selector_resolve_name() {
    local query="$1"
    local options=()
    local lowered_query lowered_option name idx i match_count=0 match_name=""

    while IFS= read -r name; do
        options+=("$name")
    done < <(list_account_names)

    if [[ "$query" =~ ^[0-9]+$ ]]; then
        idx=$((10#$query - 1))
        if [[ $idx -ge 0 && $idx -lt ${#options[@]} ]]; then
            echo "${options[$idx]}"
            return 0
        fi
        return 1
    fi

    lowered_query=$(printf '%s' "$query" | tr '[:upper:]' '[:lower:]')
    for ((i=0; i<${#options[@]}; i++)); do
        lowered_option=$(printf '%s' "${options[$i]}" | tr '[:upper:]' '[:lower:]')
        if [[ "$lowered_option" == "$lowered_query" ]]; then
            echo "${options[$i]}"
            return 0
        fi

        case "$lowered_option" in
            "$lowered_query"*)
                match_count=$((match_count + 1))
                match_name="${options[$i]}"
                ;;
        esac
    done

    if [[ $match_count -eq 1 ]]; then
        echo "$match_name"
        return 0
    fi

    if [[ $match_count -gt 1 ]]; then
        return 2
    fi

    return 1
}

selector_with_menu() {
    local options=()
    local name menu_result menu_index
    local details="Use ↑/↓ to move, Enter to select, q or Esc to cancel."

    while IFS= read -r name; do
        options+=("${name} <$(get_account_field "$name" email)> ($(get_account_field "$name" host_alias))")
    done < <(list_account_names)

    if [[ ${#options[@]} -eq 0 ]]; then
        return 1
    fi

    menu_result=$(run_arrow_menu "gitacc Accounts" "$details" "${options[@]}") || return 1
    if [[ "$menu_result" == "cancel" ]]; then
        GITACC_SELECTION=""
        GITACC_CANCELLED=1
        return 0
    fi

    menu_index=$menu_result
    GITACC_SELECTION="$(list_account_names | sed -n "$((menu_index + 1))p")"
    return 0
}

show_status_screen() {
    local repo remote_url remote_host git_name git_email account_from_email account_from_remote loaded_keys body

    repo="$(pwd)"
    remote_url="$(git remote get-url origin 2>/dev/null || echo 'none')"
    remote_host="$(get_remote_host)"
    git_name="$(git config user.name 2>/dev/null || echo 'not set')"
    git_email="$(git config user.email 2>/dev/null || echo 'not set')"
    account_from_email="$(get_account_name_by_email "$git_email")"
    account_from_remote="$(get_account_name_by_host_alias "$remote_host")"
    loaded_keys="$(ssh-add -l 2>/dev/null || echo 'No SSH keys currently loaded.')"

    body=$(cat <<EOF
Directory: ${repo}
Git user.name: ${git_name}
Git user.email: ${git_email} (${account_from_email:-unknown})
Origin remote: ${remote_url} (${account_from_remote:-unknown})

Loaded SSH keys:
${loaded_keys}
EOF
)

    show_text_screen "gitacc Status" "$body"
}

command_dashboard() {
    local items=("Switch account" "Add account" "Delete account" "Show status" "List accounts" "Help" "Quit")
    local account_count current_account most_used most_used_name most_used_count details result

    while true; do
        account_count=$(count_accounts)
        current_account=$(get_current_account_name)
        most_used=$(get_most_used_account)
        most_used_name="none"
        most_used_count=0
        if [[ -n "$most_used" ]]; then
            most_used_name="${most_used%%=*}"
            most_used_count="${most_used##*=}"
        fi

        details=$(cat <<EOF
Accounts: ${account_count}
Current account: ${current_account:-none}
Most used account: ${most_used_name} (${most_used_count} switches)

Use ↑/↓ to move, Enter to select, q or Esc to quit.
EOF
)

        result=$(run_arrow_menu "gitacc Dashboard" "$details" "${items[@]}") || return 1

        case "$result" in
            cancel)
                GITACC_CANCELLED=1
                GITACC_ACTION=""
                return 0
                ;;
            0)
                GITACC_ACTION="switch"
                return 0
                ;;
            1)
                GITACC_ACTION="add"
                return 0
                ;;
            2)
                GITACC_ACTION="delete"
                return 0
                ;;
            3)
                show_status_screen
                ;;
            4)
                show_text_screen "gitacc Accounts" "$(build_accounts_screen_text)"
                ;;
            5)
                show_text_screen "gitacc Help" "$(usage)"
                ;;
            6)
                GITACC_CANCELLED=1
                GITACC_ACTION=""
                return 0
                ;;
        esac
    done
}

selector_with_fzf() {
    local options=()
    local name selection

    while IFS= read -r name; do
        options+=("$name")
    done < <(list_account_names)

    selection=$(printf '%s\n' "${options[@]}" | fzf --prompt="Select GitHub account: " --height=10 --reverse) || {
        GITACC_CANCELLED=1
        return 1
    }
    GITACC_SELECTION="$selection"
    return 0
}

selector_with_prompt() {
    local show_list="${1:-1}"
    local input=""
    local resolved_name=""
    local resolve_code=0

    if [[ "$show_list" == "1" ]]; then
        print_account_list
    fi

    while true; do
        printf "Select account by number or name (q to cancel): "
        if ! IFS= read -r input; then
            return 1
        fi

        input=$(trim_input "$input")

        if [[ -z "$input" ]]; then
            continue
        fi

        if is_quit_input "$input"; then
            GITACC_SELECTION=""
            GITACC_CANCELLED=1
            return 0
        fi

        if resolved_name=$(selector_resolve_name "$input"); then
            GITACC_SELECTION="$resolved_name"
            return 0
        else
            resolve_code=$?
            if [[ $resolve_code -eq 2 ]]; then
                log_warn "More than one account matches '$input'. Please be more specific."
            else
                log_warn "No account matches '$input'."
            fi
        fi
    done
}

selector() {
    local options=()
    local name
    while IFS= read -r name; do
        options+=("$name")
    done < <(list_account_names)

    if [[ ${#options[@]} -eq 0 ]]; then
        show_no_accounts_message
        return 1
    fi

    if [[ ${#options[@]} -eq 1 ]]; then
        GITACC_SELECTION="${options[0]}"
        return 0
    fi

    if ! [[ -t 0 && -t 1 ]]; then
        die "Interactive selector requires a terminal. Use 'gitacc <name>' when no tty is available."
    fi

    if selector_with_menu; then
        return 0
    fi

    selector_with_prompt
}

# =============================================================================
# Commands
# =============================================================================

cmd_switch() {
    local name="$1"
    if ! account_exists "$name"; then
        die "Account '${name}' not found. Run: gitacc list"
    fi

    local acc_name acc_email acc_key acc_host
    acc_name=$(get_account_field "$name" name)
    acc_email=$(get_account_field "$name" email)
    acc_key=$(expand_path "$(get_account_field "$name" key)")
    acc_host=$(get_account_field "$name" host_alias)

    ensure_key "$acc_key" "$name"
    add_ssh_host "$acc_host" "$acc_key"
    switch_ssh_key "$acc_key" "$name"

    if in_git_repo; then
        set_git_identity "$acc_name" "$acc_email"
        rewrite_remote "$acc_host"
    else
        log_warn "Not inside a Git repository. Skipping repo-local git config and remote update."
    fi

    test_github_connection "$acc_host" "$name"
    record_account_usage "$name"
    log_ok "Switched to '${name}' account."
}

cmd_list() {
    ensure_accounts_file
    if ! has_accounts; then
        show_no_accounts_message
        return 0
    fi

    print_account_list

    if [[ -t 0 && -t 1 ]]; then
        GITACC_SELECTION=""
        GITACC_CANCELLED=0
        if selector && [[ -n "$GITACC_SELECTION" ]]; then
            cmd_switch "$GITACC_SELECTION"
        elif [[ "$GITACC_CANCELLED" == "1" ]]; then
            log_info "Cancelled."
        fi
    fi
}

cmd_add() {
    ensure_accounts_file
    echo ""
    log_title "Add new GitHub account"

    local name email full_name key_path host_alias
    local generated_key=0
    local auth_output=""
    local generate_key_choice=""

    prompt_text name "Account short name (e.g. work, personal, client-a, or q to cancel): " || return 0
    name=$(printf '%s' "$name" | tr -d '[:space:]')
    if [[ -z "$name" ]]; then
        die "Account name cannot be empty."
    fi
    if account_exists "$name"; then
        die "Account '${name}' already exists."
    fi

    prompt_text full_name "Git user.name (q to cancel): " || return 0
    prompt_text email "Git user.email (q to cancel): " || return 0
    prompt_text_with_default key_path "SSH private key path [~/.ssh/id_ed25519_${name}] (q to cancel): " "$HOME/.ssh/id_ed25519_${name}" || return 0
    key_path=$(expand_path "$key_path")

    prompt_text_with_default host_alias "SSH host alias [github-${name}] (q to cancel): " "github-${name}" || return 0

    if [[ ! -f "$key_path" ]]; then
        log_warn "Private key not found at ${key_path}."
        prompt_yes_no generate_key_choice "Generate a new SSH key now? [Y/n/q]: " y || return 0
        if [[ "$generate_key_choice" == "yes" ]]; then
            ssh-keygen -t ed25519 -C "$email" -f "$key_path"
            generated_key=1
            log_ok "SSH key generated."
        else
            die "Cannot add account without a valid SSH key."
        fi
    fi

    if [[ ! -f "${key_path}.pub" ]]; then
        die "Public key missing: ${key_path}.pub"
    fi

    # Append to accounts file
    cat >> "$ACCOUNTS_FILE" <<EOF

[${name}]
name = ${full_name}
email = ${email}
key = ${key_path}
host_alias = ${host_alias}
EOF

    add_ssh_host "$host_alias" "$key_path"

    log_ok "Account '${name}' added."
    log_info "Public key to add to GitHub:"
    cat "${key_path}.pub"

    if github_connection_works "$host_alias" auth_output; then
        log_ok "GitHub says: ${auth_output}"
        return
    fi

    if [[ "$generated_key" -eq 1 ]]; then
        log_warn "This is a new SSH key, so GitHub still needs it added to your account."
    else
        log_warn "GitHub does not recognize this SSH key yet."
    fi

    guide_github_key_setup "$key_path" "$email"
    wait_for_github_key_registration "$host_alias"
}

cmd_delete() {
    local name="$1"
    local confirm=""

    if [[ -z "${name:-}" ]]; then
        die "Usage: gitacc delete <name>"
    fi
    if ! account_exists "$name"; then
        die "Account '${name}' not found."
    fi

    local host_alias
    host_alias=$(get_account_field "$name" host_alias)

    prompt_yes_no confirm "Delete account '${name}'? [y/N/q]: " n || return 0
    if [[ "$confirm" != "yes" ]]; then
        log_info "Cancelled."
        return
    fi

    # Remove section from accounts file
    awk -v acc="$name" '
        $0 ~ "^\\[" acc "\\]$" { in_section=1; next }
        /^\[/ { in_section=0 }
        !in_section { print }
    ' "$ACCOUNTS_FILE" > "${ACCOUNTS_FILE}.tmp"
    mv "${ACCOUNTS_FILE}.tmp" "$ACCOUNTS_FILE"

    remove_ssh_host "$host_alias"
    remove_account_usage "$name"

    log_ok "Account '${name}' deleted."
}

cmd_status() {
    local repo
    local remote_url="none"
    local remote_host=""
    local git_name="not set"
    local git_email="not set"
    local account_from_email=""
    local account_from_remote=""

    repo="$(pwd)"

    echo ""
    echo "Current directory: ${repo}"

    if in_git_repo; then
        remote_url="$(git remote get-url origin 2>/dev/null || echo 'none')"
        remote_host="$(get_remote_host)"
        git_name="$(git config user.name 2>/dev/null || echo 'not set')"
        git_email="$(git config user.email 2>/dev/null || echo 'not set')"
        account_from_email="$(get_account_name_by_email "$git_email")"
        account_from_remote="$(get_account_name_by_host_alias "$remote_host")"
    else
        echo "Git repository:   no"
        echo ""
    fi

    echo "Git user.name:     ${git_name}"
    echo "Git user.email:    ${git_email} (${account_from_email:-unknown})"
    echo "Origin remote:     ${remote_url} (${account_from_remote:-unknown})"
    echo ""

    if ssh-add -l >/dev/null 2>&1; then
        echo "Loaded SSH keys:"
        ssh-add -l | sed 's/^/  • /'
    else
        log_warn "No SSH keys currently loaded in ssh-agent."
    fi
    echo ""
}

# =============================================================================
# Main
# =============================================================================

main() {
    ensure_accounts_file
    ensure_usage_file

    local cmd="${1:-}"

    # If no command, show interactive dashboard
    if [[ -z "$cmd" ]]; then
        GITACC_ACTION=""
        GITACC_CANCELLED=0
        command_dashboard || return

        case "$GITACC_ACTION" in
            switch)
                if ! has_accounts; then
                    show_no_accounts_message
                    return
                fi
                GITACC_SELECTION=""
                GITACC_CANCELLED=0
                selector || return
                if [[ -n "$GITACC_SELECTION" ]]; then
                    cmd_switch "$GITACC_SELECTION"
                elif [[ "$GITACC_CANCELLED" == "1" ]]; then
                    log_info "Cancelled."
                fi
                ;;
            add)
                cmd_add
                ;;
            delete)
                if ! has_accounts; then
                    show_no_accounts_message
                    return
                fi
                GITACC_SELECTION=""
                GITACC_CANCELLED=0
                selector || return
                if [[ -n "$GITACC_SELECTION" ]]; then
                    cmd_delete "$GITACC_SELECTION"
                elif [[ "$GITACC_CANCELLED" == "1" ]]; then
                    log_info "Cancelled."
                fi
                ;;
            list)
                cmd_list
                ;;
            help)
                usage
                ;;
            version)
                print_version
                ;;
            "")
                if [[ "$GITACC_CANCELLED" == "1" ]]; then
                    log_info "Cancelled."
                fi
                ;;
        esac
        return
    fi

    case "$cmd" in
        list|ls)
            cmd_list
            ;;

        add)
            cmd_add
            ;;

        delete|del|rm)
            cmd_delete "${2:-}"
            ;;

        status|st)
            cmd_status
            ;;

        help|--help|-h)
            usage
            ;;

        version|--version|-V)
            print_version
            ;;

        *)
            # Could be an account name
            if account_exists "$cmd"; then
                cmd_switch "$cmd"
            else
                log_err "Unknown command or account: ${cmd}"
                usage
                exit 1
            fi
            ;;
    esac
}

main "$@"
